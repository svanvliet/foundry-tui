/* Foundry TUI Styles - Claude Code inspired */

Screen {
    layout: grid;
    grid-size: 1;
    grid-rows: 1fr auto auto;
}

/* Chat message area */
#chat-container {
    height: 100%;
    scrollbar-gutter: stable;
}

#chat-log {
    height: auto;
    padding: 0 2;
}

/* Messages - invisible containers */
.message {
    margin: 0 0 1 0;
    padding: 0;
}

.message-user {
    color: $text;
}

.message-assistant {
    color: $text;
}

.message-error {
    color: #ff6b6b;
}

.message-system {
    color: $text-muted;
}

/* Input area - completely invisible */
#input-container {
    height: auto;
    max-height: 10;
    padding: 0 2;
}

#message-input {
    height: auto;
    min-height: 1;
    max-height: 8;
    margin: 0;
    border: none;
    background: transparent;
    padding: 0;
}

#message-input:focus {
    border: none;
    background: transparent;
}

/* Status bar - minimal, blends in */
StatusBar {
    height: 1;
    padding: 0 2;
    color: $text-muted;
}

/* Welcome message */
#welcome {
    text-align: center;
    padding: 3;
    color: $text-muted;
}

/* Model picker */
ModelPicker > Vertical {
    background: $surface;
    border: round $primary;
    padding: 1 2;
}

/* Conversation picker */
ConversationPicker > Vertical {
    background: $surface;
    border: round $primary;
    padding: 1 2;
}
