# Foundry TUI Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Azure General (for setup scripts)
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=foundry-testing-rg
AZURE_LOCATION=eastus

# =============================================================================
# Azure OpenAI (GPT, o-series models)
# =============================================================================
# Get these from: Azure Portal > Azure OpenAI > Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://your-region.api.cognitive.microsoft.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# =============================================================================
# Azure AI Services (DeepSeek, Grok, Kimi)
# =============================================================================
# Get these from: Azure Portal > Azure AI Services > Keys and Endpoint
AZURE_AI_ENDPOINT=https://your-region.api.cognitive.microsoft.com/
AZURE_AI_API_KEY=your-azure-ai-api-key

# =============================================================================
# Serverless Endpoints (Marketplace models like Mistral)
# =============================================================================
# Each serverless model has its own endpoint and key
# Get these from: Azure AI Foundry > Deployments > your-model > Endpoint
SERVERLESS_ENDPOINT_MISTRAL_SMALL=https://your-deployment.eastus.models.ai.azure.com
SERVERLESS_KEY_MISTRAL_SMALL=your-serverless-api-key

# =============================================================================
# App Settings (optional - these have defaults)
# =============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
FOUNDRY_TUI_LOG_LEVEL=INFO

# Context ratio: how much of the model's context window to use (0.0-1.0)
FOUNDRY_TUI_CONTEXT_RATIO=0.8

# Token count threshold for cost warnings (status bar turns yellow/red)
FOUNDRY_TUI_COST_WARNING_THRESHOLD=10000

# =============================================================================
# Tool Calling - Web Search (optional)
# =============================================================================
# Enables web search as a tool for models that support function calling
# Get a free API key at: https://tavily.com (1,000 searches/month free)
TAVILY_API_KEY=your-tavily-api-key
